# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit it.

# A long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Secret key required to hit the /admin/* endpoints.
ADMIN_KEY=change-me-too

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example for Vercel: https://chicken-joe.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
